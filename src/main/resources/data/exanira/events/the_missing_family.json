{
  "id": "the_missing_family",
  "type": "side",
  "offlineFallback": "ignore",
  "startScene": "roadside_meeting",
  "scenes": {
    "roadside_meeting": {
      "dialogue": [
        "A man stands beside a line of abandoned cars.",
        "He carefully places flyers beneath windshield wipers.",
        "Some of the paper has yellowed with age.",
        "Others look freshly written.",
        "Every flyer shows the same two names.",
        "'Have you seen my wife and daughter?'"
      ],
      "choices": [
        {
          "text": "Approach him",
          "nextScene": "his_story"
        },
        {
          "text": "Read a flyer",
          "requires": { "perception": 3 },
          "checkType": "hard",
          "nextScene": "flyer_details",
          "lockedText": "The writing is too faded to make out."
        },
        {
          "text": "Keep walking",
          "nextScene": "leave"
        }
      ]
    },

    "flyer_details": {
      "dialogue": [
        "The flyer contains more than names.",
        "'Pink backpack.'",
        "'Missing front tooth.'",
        "'Afraid of thunderstorms.'",
        "'Loves drawing birds.'",
        "These aren't descriptions.",
        "They're memories."
      ],
      "choices": [
        {
          "text": "Speak to the man",
          "nextScene": "his_story"
        },
        {
          "text": "Leave",
          "nextScene": "leave"
        }
      ]
    },

    "his_story": {
      "dialogue": [
        "He notices you looking.",
        "'I know what you're going to ask.'",
        "'I'm still looking for them.'",
        "He stares down the road.",
        "'I left for water.'",
        "'My daughter asked how long I'd be gone.'",
        "'I told her twenty seconds.'",
        "'I was gone longer than twenty seconds.'"
      ],
      "choices": [
        {
          "text": "Ask where he lost them",
          "nextScene": "where_lost"
        },
        {
          "text": "Ask how long he's searched",
          "nextScene": "search_length"
        },
        {
          "text": "Offer to help",
          "nextScene": "investigation_hub"
        }
      ]
    },

    "where_lost": {
      "dialogue": [
        "'Evacuation Point Twelve.'",
        "'Near the highway.'",
        "'People were screaming names.'",
        "'The barricades broke.'",
        "'Everything happened at once.'",
        "'When I got back... they were gone.'"
      ],
      "choices": [
        {
          "text": "Offer to help search",
          "nextScene": "investigation_hub"
        },
        {
          "text": "Ask how long he's searched",
          "nextScene": "search_length"
        }
      ]
    },

    "search_length": {
      "dialogue": [
        "'Eight months.'",
        "He says it casually.",
        "Like he's answering a question about the weather.",
        "'Maybe nine.'",
        "'Days stopped meaning much after a while.'",
        "'But if I stop looking...'",
        "He never finishes the sentence."
      ],
      "choices": [
        {
          "text": "Offer to help",
          "nextScene": "investigation_hub"
        },
        {
          "text": "Leave",
          "nextScene": "leave"
        }
      ]
    },

    "investigation_hub": {
      "dialogue": [
        "'Thank you,' he says quietly.",
        "'Most people stopped listening months ago.'",
        "",
        "Where should you search?"
      ],
      "choices": [
        {
          "text": "Search abandoned vehicles",
          "nextScene": "vehicles"
        },
        {
          "text": "Search the evacuation checkpoint",
          "nextScene": "checkpoint"
        },
        {
          "text": "Search the nearby woods",
          "nextScene": "woods"
        },
        {
          "text": "Search the convoy route",
          "requires": { "survival": 4 },
          "checkType": "hard",
          "nextScene": "convoy_route",
          "lockedText": "You don't know where the convoy traveled."
        }
      ]
    },

    "vehicles": {
      "dialogue": [
        "You spend hours searching abandoned cars.",
        "Most contain nothing useful.",
        "Then you find a small pink backpack trapped beneath a collapsed guardrail."
      ],
      "choices": [
        {
          "text": "Open the backpack",
          "nextScene": "backpack_contents"
        },
        {
          "text": "Bring it to the father unopened",
          "nextScene": "show_backpack"
        }
      ]
    },

    "backpack_contents": {
      "dialogue": [
        "Inside is a crayon drawing.",
        "A family stands holding hands.",
        "A smiling little girl stands between her parents.",
        "Written at the bottom:",
        "'Daddy always comes back.'"
      ],
      "choices": [
        {
          "text": "Show him",
          "nextScene": "show_backpack"
        },
        {
          "text": "Hide the drawing",
          "nextScene": "hide_backpack"
        }
      ]
    },

    "show_backpack": {
      "dialogue": [
        "He recognizes it immediately.",
        "His hands begin shaking.",
        "'She took this everywhere.'",
        "He opens it.",
        "His expression collapses when he sees the drawing.",
        "'I told her that.'",
        "'I always told her I'd come back.'"
      ],
      "choices": [
        {
          "text": "Keep searching",
          "nextScene": "checkpoint"
        },
        {
          "text": "Tell him they may be gone",
          "nextScene": "first_doubt"
        }
      ]
    },

    "hide_backpack": {
      "dialogue": [
        "You put the drawing away.",
        "Some discoveries feel cruel.",
        "The father never sees it."
      ],
      "choices": [
        {
          "text": "Continue searching",
          "nextScene": "checkpoint"
        }
      ]
    },

    "first_doubt": {
      "dialogue": [
        "'No.'",
        "The answer comes immediately.",
        "'They're alive.'",
        "'I would know if they weren't.'",
        "But for the first time, his voice sounds uncertain."
      ],
      "choices": [
        {
          "text": "Continue investigating",
          "nextScene": "checkpoint"
        }
      ]
    },

    "checkpoint": {
      "dialogue": [
        "The evacuation checkpoint is mostly ruins.",
        "Burned tents.",
        "Collapsed barricades.",
        "A sea of scattered paperwork."
      ],
      "choices": [
        {
          "text": "Search the records",
          "requires": { "intelligence": 3 },
          "checkType": "hard",
          "nextScene": "records_found",
          "lockedText": "Most of the records are unreadable."
        },
        {
          "text": "Search for personal belongings",
          "nextScene": "checkpoint_items"
        }
      ]
    },

    "records_found": {
      "dialogue": [
        "Most records are ruined.",
        "One ledger survived.",
        "You find both names.",
        "'Transferred to Medical Convoy 6.'"
      ],
      "choices": [
        {
          "text": "Show him the record",
          "nextScene": "record_reveal"
        },
        {
          "text": "Keep it to yourself",
          "nextScene": "woods"
        }
      ]
    },

    "record_reveal": {
      "dialogue": [
        "His eyes widen.",
        "'Transferred.'",
        "'See?'",
        "'I told you.'",
        "'They got out.'",
        "Hope returns to his face with frightening speed."
      ],
      "choices": [
        {
          "text": "Continue searching",
          "nextScene": "woods"
        }
      ]
    },

    "checkpoint_items": {
      "dialogue": [
        "You find a child's shoe.",
        "Small.",
        "Covered in dried mud.",
        "The father stares at it for a long time.",
        "'It's not hers.'",
        "He sounds like he's trying to convince himself."
      ],
      "choices": [
        {
          "text": "Continue searching",
          "nextScene": "woods"
        }
      ]
    },

    "woods": {
      "dialogue": [
        "The woods nearby contain signs of an old camp.",
        "Fire pits.",
        "Makeshift shelters.",
        "Pieces of torn fabric."
      ],
      "choices": [
        {
          "text": "Search thoroughly",
          "requires": { "perception": 4 },
          "checkType": "hard",
          "nextScene": "letter_found",
          "lockedText": "You can't find anything useful."
        },
        {
          "text": "Return to the road",
          "nextScene": "convoy_route"
        }
      ]
    },

    "letter_found": {
      "dialogue": [
        "You discover a sealed letter beneath a rotted sleeping bag.",
        "The handwriting matches the father's flyers.",
        "",
        "'If you're reading this, I couldn't find my way back.'",
        "'She keeps asking when you'll return.'",
        "'I keep telling her soon.'",
        "'Please don't blame yourself.'"
      ],
      "choices": [
        {
          "text": "Show him the letter",
          "nextScene": "letter_reveal"
        },
        {
          "text": "Hide it",
          "nextScene": "convoy_route"
        }
      ]
    },

    "letter_reveal": {
      "dialogue": [
        "He reads the letter several times.",
        "Each time more slowly.",
        "",
        "'She knew me too well.'",
        "",
        "'She already knew I'd blame myself.'"
      ],
      "choices": [
        {
          "text": "Continue searching",
          "nextScene": "convoy_route"
        }
      ]
    },

    "convoy_route": {
      "dialogue": [
        "Following the old convoy route takes most of the day.",
        "The father grows quieter with every mile.",
        "",
        "'Sometimes I still hear her.'",
        "",
        "'Not really.'",
        "",
        "'Just in my head.'"
      ],
      "choices": [
        {
          "text": "Search for convoy remains",
          "requires": { "survival": 5 },
          "checkType": "hard",
          "nextScene": "truth_site",
          "lockedText": "You can't determine where the convoy ended."
        },
        {
          "text": "Tell him that's normal",
          "nextScene": "comfort_father"
        },
        {
          "text": "Tell him he needs to accept reality",
          "nextScene": "push_acceptance"
        }
      ]
    },

    "comfort_father": {
      "dialogue": [
        "He nods.",
        "'Maybe.'",
        "",
        "'I just don't want to forget her voice.'"
      ],
      "choices": [
        {
          "text": "Search harder",
          "nextScene": "truth_site"
        }
      ]
    },

    "push_acceptance": {
      "dialogue": [
        "He stops walking.",
        "",
        "'You think I don't know what you're saying?'",
        "",
        "'You think I haven't thought it every day?'",
        "",
        "'If I stop looking...'",
        "",
        "'Then they're really gone.'"
      ],
      "choices": [
        {
          "text": "Keep searching",
          "nextScene": "truth_site"
        }
      ]
    },

    "truth_site": {
      "dialogue": [
        "You find the remains of Medical Convoy 6.",
        "The vehicles are rusted shells.",
        "Most records were destroyed.",
        "One waterproof container survived."
      ],
      "choices": [
        {
          "text": "Read the records",
          "requires": { "intelligence": 5 },
          "checkType": "hard",
          "nextScene": "full_truth",
          "lockedText": "The records are too damaged to understand."
        },
        {
          "text": "Destroy the records",
          "nextScene": "mercy_ending"
        },
        {
          "text": "Leave without reading",
          "nextScene": "hope_ending"
        }
      ]
    },

    "full_truth": {
      "dialogue": [
        "The convoy was attacked.",
        "",
        "His wife was bitten defending her daughter.",
        "",
        "She locked herself outside the vehicle to buy time.",
        "",
        "The daughter survived.",
        "",
        "Rescuers repeatedly tried to evacuate her.",
        "",
        "She refused.",
        "",
        "'My dad said he'd come back.'",
        "",
        "The final report states:",
        "",
        "'Child repeatedly refused transport.'",
        "'Believed father would return.'",
        "'Deceased from dehydration.'"
      ],
      "choices": [
        {
          "text": "Show him everything",
          "nextScene": "truth_ending"
        },
        {
          "text": "Destroy the records",
          "nextScene": "mercy_ending"
        },
        {
          "text": "Lie and tell him they escaped",
          "nextScene": "false_hope_ending"
        }
      ]
    },

    "truth_ending": {
      "dialogue": [
        "He reads every page.",
        "",
        "Then reads them again.",
        "",
        "His hands shake violently.",
        "",
        "'She waited for me.'",
        "",
        "The words barely leave his mouth.",
        "",
        "'God...' ",
        "",
        "'She waited for me.'",
        "",
        "For the first time since you've known him, he cries.",
        "",
        "Not loudly.",
        "",
        "Not dramatically.",
        "",
        "Just quietly.",
        "",
        "At sunset he removes every flyer from every car.",
        "",
        "The last one remains in his hand for a long time.",
        "",
        "Then he folds it carefully and places it in his pocket.",
        "",
        "For the first time in months, he stops searching."
      ],
      "choices": []
    },

    "mercy_ending": {
      "dialogue": [
        "The records burn quickly.",
        "",
        "The truth disappears with them.",
        "",
        "He never learns what happened.",
        "",
        "He never learns his daughter waited.",
        "",
        "He never learns his wife died protecting her.",
        "",
        "As you leave, he thanks you for helping.",
        "",
        "You aren't sure whether what you did was kindness or cowardice."
      ],
      "choices": []
    },

    "false_hope_ending": {
      "dialogue": [
        "'They survived,' you tell him.",
        "",
        "The smile that appears on his face is heartbreaking.",
        "",
        "Months later you return.",
        "",
        "The road is covered in flyers.",
        "",
        "Hundreds of them.",
        "",
        "Trees.",
        "Road signs.",
        "Guardrails.",
        "",
        "The names are everywhere.",
        "",
        "He is still searching.",
        "",
        "Now because of you."
      ],
      "choices": []
    },

    "hope_ending": {
      "dialogue": [
        "You never learn the full truth.",
        "",
        "Neither does he.",
        "",
        "As you leave, he places another flyer beneath another windshield wiper.",
        "",
        "The same names.",
        "",
        "The same question.",
        "",
        "The same hope.",
        "",
        "The same road."
      ],
      "choices": []
    },

    "leave": {
      "dialogue": [
        "You continue walking.",
        "",
        "Behind you, the man keeps placing flyers.",
        "",
        "One after another.",
        "",
        "On cars that will never move.",
        "",
        "For people who may never come home."
      ],
      "choices": []
    }
  }
